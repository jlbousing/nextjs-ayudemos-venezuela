# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo servidor: nunca exponer al cliente (Dashboard → API → service_role)
# Requerida para registrar usuarios sin verificar correo.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL pública de la app (correos y confirmación de email en producción).
# En Netlify no suele hacer falta: la app usa la variable URL del deploy.
# No uses localhost aquí en producción.
NEXT_PUBLIC_APP_URL=https://tu-sitio.netlify.app

# Resend (https://resend.com) — notificaciones por correo
RESEND_API_KEY=re_tu_api_key
EMAIL_FROM=Ayudemos Venezuela <onboarding@resend.dev>
