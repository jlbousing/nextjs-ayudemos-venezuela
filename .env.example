# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo servidor: nunca exponer al cliente (Dashboard → API → service_role)
# Requerida para registrar usuarios sin verificar correo.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL pública de la app (correos y confirmación de email en producción).
# En Amplify configura APP_URL o NEXT_PUBLIC_APP_URL con tu dominio
# (p. ej. https://main.d1234abcd.amplifyapp.com o tu dominio custom).
# No uses localhost aquí en producción.
APP_URL=https://main.d1234abcd.amplifyapp.com
NEXT_PUBLIC_APP_URL=https://main.d1234abcd.amplifyapp.com

# Resend (https://resend.com) — notificaciones por correo
RESEND_API_KEY=re_tu_api_key
EMAIL_FROM=Ayudemos Venezuela <hola@ayudemos-venezuela.com>

# Supabase Auth (Dashboard → Authentication → Emails → SMTP Settings):
# Configura SMTP con Resend para evitar el límite "email rate limit exceeded".
# Host: smtp.resend.com | Puerto: 465 | Usuario: resend | Contraseña: tu RESEND_API_KEY
